# xchat-playground environment variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ── Webhook signature validation ──────────────────────────────────────────────
# Your X app's consumer secret (OAuth 1.0a)
# Found in: developer.x.com → Your App → Keys and Tokens → Consumer Keys
CONSUMER_SECRET=

# ── OAuth 2.0 (for live bot testing) ─────────────────────────────────────────
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
# Must match exactly what's registered in X Developer Portal
# Use http://127.0.0.1:PORT/callback (not localhost — they behave differently)
OAUTH_REDIRECT_URI=http://127.0.0.1:7474/callback

# ── Activity Stream ───────────────────────────────────────────────────────────
BEARER_TOKEN=

# ── Server config ─────────────────────────────────────────────────────────────
PLAYGROUND_PORT=7474
PLAYGROUND_HOST=127.0.0.1
